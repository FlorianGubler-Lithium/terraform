version: 2
renderer: networkd
ethernets:
  # External/Internet interface - ens18
  ens18:
    addresses:
      - ${vm_network_devices[0].ip}/24
    dhcp4: false
    routes:
      - to: default
        via: 192.168.1.1
        metric: 100
  # Infra zone interface - ens19
  ens19:
    addresses:
      - ${vm_network_devices[1].ip}/24
    dhcp4: false
    routes:
      - to: 10.30.0.0/24
        via: 10.30.0.1
        metric: 200