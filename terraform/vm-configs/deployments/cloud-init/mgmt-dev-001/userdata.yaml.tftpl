#cloud-config
# Debian 12 cloud-init configuration for Kubernetes nodes and infrastructure VMs

hostname: ${hostname}
preserve_hostname: false

# Set timezone
timezone: Europe/Zurich

# Update system
apt:
  preserve_sources_list: true
  http_proxy: "http://10.30.0.11:3128"
  https_proxy: "http://10.30.0.11:3128"
  primary:
    - arches: [amd64, i386]
      uri: "http://deb.debian.org/debian"
  security:
    - arches: [amd64, i386]
      uri: "http://security.debian.org/debian-security"

# Users and groups
users:
  - name: debian
    gecos: Debian User
    sudo: ALL=(ALL) NOPASSWD:ALL
    groups: sudo,docker,wheel
    shell: /bin/bash
    lock_passwd: false
    plain_text_passwd: "${vm_password}"
    ssh_authorized_keys:
      - "${ssh_public_key}"
  - name: root
    lock_passwd: false
    plain_text_passwd: "${vm_password}"

package_update: true
package_upgrade: true
package_reboot_if_required: true

# Install required packages
packages:
  - curl
  - wget
  - git
  - vim
  - htop
  - net-tools
  - jq
  - unzip
  - openssh-server
  - openssh-client
  - ca-certificates
  - gnupg
  - apt-transport-https
  - qemu-guest-agent

# Configure SSH
ssh:
  emit_keys_to_console: false

# Write GitHub Actions runner setup script
write_files:
  - path: /opt/github-runner-setup.sh
    permissions: '0755'
    encoding: base64
    content: |
      ${extra.vars["github_runner_setup_script_content"]}

# Run commands to ensure qemu-guest-agent is enabled and running
runcmd:
  - systemctl enable qemu-guest-agent
  - systemctl start qemu-guest-agent
  - chmod +x /opt/github-runner-setup.sh
  - /opt/github-runner-setup.sh "${github_runner_org}" "${github_runner_token}"

# Final message
final_message: "System booted successfully. Instance uptime: $UPTIME seconds"

